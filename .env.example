# ============================================================
# GymTracker - Automação de Processamento de GIFs de Exercícios
# ============================================================
# Copie este arquivo para .env e preencha os valores.

# ===== CONFIGURAÇÃO DE IA =====
# Modo: "cloud" (OpenAI/Google) ou "local" (Ollama/LM Studio)
AI_MODE=cloud

# Provedor cloud: "openai" ou "google"
AI_PROVIDER=openai

# Chaves de API (apenas para modo cloud)
OPENAI_API_KEY=sk-sua-chave-openai-aqui
GOOGLE_API_KEY=sua-chave-google-aqui

# Modelo (opcional - usa o padrão do provedor se vazio)
# OpenAI: gpt-4o, gpt-4o-mini, gpt-4.1, etc.
# Google: gemini-2.5-flash, gemini-2.5-pro, etc.
AI_MODEL=

# Limite de requisições por minuto para a IA
AI_RATE_LIMIT=15

# Inclui few-shot examples no system prompt (true/false)
# Útil para modelos locais menores que precisam de referências
AI_USE_FEW_SHOT=false

# ===== CONFIGURAÇÃO LOCAL (Ollama / LM Studio) =====
# Endpoint compatível com OpenAI /v1/chat/completions
LOCAL_API_URL=http://localhost:11434/v1/chat/completions
# Nome do modelo com suporte a visão (ex: llama3.2-vision, llava, bakllava)
LOCAL_MODEL=llama3.2-vision

# ===== CONFIGURAÇÃO DA API BACKEND =====
API_BASE_URL=http://localhost:8000
API_EMAIL=admin@gymtracker.com
API_PASSWORD=securepass123

# Limite de requisições por minuto para a API
API_RATE_LIMIT=30

# ===== FILE SYSTEM =====
# Caminho absoluto ou relativo para a raiz dos GIFs
GIF_ROOT_PATH=./1.300 GIFs de Musculação
# Nome da subpasta onde os arquivos processados serão movidos
PROCESSED_DIR=processados
